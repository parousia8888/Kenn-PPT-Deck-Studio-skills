{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/cards/**",
              "components/core/**",
              "slides/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Spectral|Source Sans 3|JetBrains Mono|Noto Serif SC|Noto Sans SC))/i]",
        "message": "Font not provided by the design system. Available: Spectral, Source Sans 3, JetBrains Mono, Noto Serif SC, Noto Sans SC."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|as|href|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, as, href, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|accent|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'accent' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetaChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|bare|style|key|ref|className|style|children)$/]",
        "message": "<MetaChip> doesn't accept that prop. Declared props: children, bare, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='OutcomeStat'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|unit|caption|source|style|key|ref|className|style|children)$/]",
        "message": "<OutcomeStat> doesn't accept that prop. Declared props: value, unit, caption, source, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlanCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:tier|price|per|items|feature|style|key|ref|className|style|children)$/]",
        "message": "<PlanCard> doesn't accept that prop. Declared props: tier, price, per, items, feature, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TeacherCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|discipline|bio|image|style|key|ref|className|style|children)$/]",
        "message": "<TeacherCard> doesn't accept that prop. Declared props: name, discipline, bio, image, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TestimonialCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:quote|name|role|style|key|ref|className|style|children)$/]",
        "message": "<TestimonialCard> doesn't accept that prop. Declared props: quote, name, role, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
