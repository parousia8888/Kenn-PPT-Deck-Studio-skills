{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/teaching/**",
              "decks/**",
              "slides/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Newsreader|Inter|JetBrains Mono|Noto Serif SC|Noto Sans SC))/i]",
        "message": "Font not provided by the design system. Available: Newsreader, Inter, JetBrains Mono, Noto Serif SC, Noto Sans SC."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|level|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, level, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ink|ox|sage|straw|ghost|ok|error)$/]",
        "message": "<Badge> variant must be one of 'ink' | 'ox' | 'sage' | 'straw' | 'ghost' | 'ok' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|as|icon|iconRight|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, as, icon, iconRight, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|sage|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'sage' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|label|children|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: variant, label, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ox|sage|note|straw)$/]",
        "message": "<Callout> variant must be one of 'ox' | 'sage' | 'note' | 'straw'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:kicker|title|accent|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: kicker, title, accent, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:none|ox|sage)$/]",
        "message": "<Card> accent must be one of 'none' | 'ox' | 'sage'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KeyTerm'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|key|ref|className|style|children)$/]",
        "message": "<KeyTerm> doesn't accept that prop. Declared props: variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='KeyTerm'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:highlight|underline|ox)$/]",
        "message": "<KeyTerm> variant must be one of 'highlight' | 'underline' | 'ox'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MarginNote'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|variant|children|key|ref|className|style|children)$/]",
        "message": "<MarginNote> doesn't accept that prop. Declared props: label, variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='MarginNote'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|ox|sage)$/]",
        "message": "<MarginNote> variant must be one of 'default' | 'ox' | 'sage'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NumberTab'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|variant|size|key|ref|className|style|children)$/]",
        "message": "<NumberTab> doesn't accept that prop. Declared props: value, label, variant, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='NumberTab'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ox|sage)$/]",
        "message": "<NumberTab> variant must be one of 'ox' | 'sage'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RuleHeading'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|variant|as|key|ref|className|style|children)$/]",
        "message": "<RuleHeading> doesn't accept that prop. Declared props: eyebrow, title, variant, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='RuleHeading'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ox|sage)$/]",
        "message": "<RuleHeading> variant must be one of 'ox' | 'sage'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RuleHeading'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:h1|h2|h3)$/]",
        "message": "<RuleHeading> as must be one of 'h1' | 'h2' | 'h3'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Step'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|body|key|ref|className|style|children)$/]",
        "message": "<Step> doesn't accept that prop. Declared props: title, body."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
