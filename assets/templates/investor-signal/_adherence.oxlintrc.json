{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "motion.js"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Manrope|Archivo|Inter|JetBrains Mono|Noto Serif SC))/i]",
        "message": "Font not provided by the design system. Available: Manrope, Archivo, Inter, JetBrains Mono, Noto Serif SC."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|dot|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, dot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:outline|accent|solid)$/]",
        "message": "<Badge> variant must be one of 'outline' | 'accent' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|as|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ghost|link)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ghost' | 'link'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|as|style|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, tone, as, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|muted|secondary)$/]",
        "message": "<Eyebrow> tone must be one of 'accent' | 'muted' | 'secondary'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiStat'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|count|prefix|suffix|decimals|caption|delta|deltaDir|size|align|style|key|ref|className|style|children)$/]",
        "message": "<KpiStat> doesn't accept that prop. Declared props: value, count, prefix, suffix, decimals, caption, delta, deltaDir, size, align, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiStat'] > JSXAttribute[name.name='deltaDir'] > Literal[value!=/^(?:up|down)$/]",
        "message": "<KpiStat> deltaDir must be one of 'up' | 'down'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiStat'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|lg|mega)$/]",
        "message": "<KpiStat> size must be one of 'sm' | 'lg' | 'mega'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiStat'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<KpiStat> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductFrame'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|chrome|label|ratio|anim|style|key|ref|className|style|children)$/]",
        "message": "<ProductFrame> doesn't accept that prop. Declared props: children, chrome, label, ratio, anim, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductFrame'] > JSXAttribute[name.name='chrome'] > Literal[value!=/^(?:bar|window|none)$/]",
        "message": "<ProductFrame> chrome must be one of 'bar' | 'window' | 'none'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|height|color|style|key|ref|className|style|children)$/]",
        "message": "<Wordmark> doesn't accept that prop. Declared props: variant, height, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:full|mark)$/]",
        "message": "<Wordmark> variant must be one of 'full' | 'mark'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
