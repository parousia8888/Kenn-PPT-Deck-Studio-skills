{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/stage/**",
              "motion/**",
              "slides/**",
              "ui_kits/launch-site/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Manrope|Hanken Grotesk|JetBrains Mono|Noto Serif SC))/i]",
        "message": "Font not provided by the design system. Available: Manrope, Hanken Grotesk, JetBrains Mono, Noto Serif SC."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|dot|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, dot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|accent|solid|muted)$/]",
        "message": "<Badge> variant must be one of 'default' | 'accent' | 'solid' | 'muted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconRight|disabled|href|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, iconRight, disabled, href, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'solid' | 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureCell'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|name|children|icon|i|style|key|ref|className|style|children)$/]",
        "message": "<FeatureCell> doesn't accept that prop. Declared props: index, name, children, icon, i, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Kicker'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|index|total|style|key|ref|className|style|children)$/]",
        "message": "<Kicker> doesn't accept that prop. Declared props: children, index, total, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MonoMetaItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|accent|key|ref|className|style|children)$/]",
        "message": "<MonoMetaItem> doesn't accept that prop. Declared props: label, value, accent."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressRail'] > JSXAttribute > JSXIdentifier[name!=/^(?:total|current|style|key|ref|className|style|children)$/]",
        "message": "<ProgressRail> doesn't accept that prop. Declared props: total, current, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScreenFrame'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|label|ratio|glow|sweep|children|style|key|ref|className|style|children)$/]",
        "message": "<ScreenFrame> doesn't accept that prop. Declared props: src, alt, label, ratio, glow, sweep, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StageNumber'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|unit|label|delta|accent|animate|countTo|style|key|ref|className|style|children)$/]",
        "message": "<StageNumber> doesn't accept that prop. Declared props: value, unit, label, delta, accent, animate, countTo, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
