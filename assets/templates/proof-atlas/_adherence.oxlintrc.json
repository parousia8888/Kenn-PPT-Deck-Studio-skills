{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/**",
              "components/core/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Manrope|Inter|JetBrains Mono|Noto Serif SC))/i]",
        "message": "Font not provided by the design system. Available: Manrope, Inter, JetBrains Mono, Noto Serif SC."
      },
      {
        "selector": "JSXOpeningElement[name.name='BarDatum'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|accent|key|ref|className|style|children)$/]",
        "message": "<BarDatum> doesn't accept that prop. Declared props: label, value, accent."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|as|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Button> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Coordinate'] > JSXAttribute > JSXIdentifier[name!=/^(?:lat|lng|raw|brackets|color|key|ref|className|style|children)$/]",
        "message": "<Coordinate> doesn't accept that prop. Declared props: lat, lng, raw, brackets, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|key|align|mono|emphasize|key|ref|className|style|children)$/]",
        "message": "<DataColumn> doesn't accept that prop. Declared props: label, key, align, mono, emphasize."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataColumn'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|right|center)$/]",
        "message": "<DataColumn> align must be one of 'left' | 'right' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EvidenceCell'] > JSXAttribute > JSXIdentifier[name!=/^(?:cellId|coord|method|id|muted|children|key|ref|className|style|children)$/]",
        "message": "<EvidenceCell> doesn't accept that prop. Declared props: cellId, coord, method, id, muted, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Metric'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|unit|label|delta|deltaDir|method|id|size|key|ref|className|style|children)$/]",
        "message": "<Metric> doesn't accept that prop. Declared props: value, unit, label, delta, deltaDir, method, id, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Metric'] > JSXAttribute[name.name='deltaDir'] > Literal[value!=/^(?:up|down)$/]",
        "message": "<Metric> deltaDir must be one of 'up' | 'down'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Metric'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xl|l|m|s)$/]",
        "message": "<Metric> size must be one of 'xl' | 'l' | 'm' | 's'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RiskMarker'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|title|id|children|key|ref|className|style|children)$/]",
        "message": "<RiskMarker> doesn't accept that prop. Declared props: level, title, id, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='RiskMarker'] > JSXAttribute[name.name='level'] > Literal[value!=/^(?:limitation|risk|caveat)$/]",
        "message": "<RiskMarker> level must be one of 'limitation' | 'risk' | 'caveat'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SourceNote'] > JSXAttribute > JSXIdentifier[name!=/^(?:method|id|label|align|key|ref|className|style|children)$/]",
        "message": "<SourceNote> doesn't accept that prop. Declared props: method, id, label, align."
      },
      {
        "selector": "JSXOpeningElement[name.name='SourceNote'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<SourceNote> align must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|index|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: variant, index, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|accent|solid|risk)$/]",
        "message": "<Tag> variant must be one of 'default' | 'accent' | 'solid' | 'risk'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
